<div class="card mx-auto" style="max-width: 800px;">
    <form method="post" action="{{ form_action }}" class="card-body">
        <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token }}"/>

        <h2 class="card-title mb-4">
            <i class="ti ti-brand-google me-2"></i>{{ __('Google SSO Authentication', 'googlessoauth') }}
        </h2>

        <div class="alert alert-info">
            {{ __('Register the following redirect URI in your Google Cloud OAuth 2.0 Client:', 'googlessoauth') }}
            <br>
            <code>{{ redirect_uri }}</code>
        </div>

        <div class="mb-3">
            <label class="form-label" for="cfg_client_id">{{ __('Client ID', 'googlessoauth') }}</label>
            <input type="text" class="form-control" id="cfg_client_id" name="client_id"
                   value="{{ client_id }}" autocomplete="off"/>
            {% if from_env.client_id %}
                <small class="form-hint text-muted">
                    {{ __('Currently provided by the GOOGLE_CLIENT_ID environment variable.', 'googlessoauth') }}
                </small>
            {% endif %}
        </div>

        <div class="mb-3">
            <label class="form-label" for="cfg_client_secret">{{ __('Client Secret', 'googlessoauth') }}</label>
            <input type="password" class="form-control" id="cfg_client_secret" name="client_secret"
                   placeholder="{{ has_secret ? '••••••••••••••••' : '' }}" autocomplete="new-password"/>
            <small class="form-hint text-muted">
                {% if has_secret %}
                    {{ __('A secret is already stored. Leave blank to keep it unchanged.', 'googlessoauth') }}
                {% else %}
                    {{ __('No secret stored yet.', 'googlessoauth') }}
                {% endif %}
                {% if from_env.client_secret %}
                    {{ __('Currently provided by the GOOGLE_CLIENT_SECRET environment variable.', 'googlessoauth') }}
                {% endif %}
            </small>
        </div>

        <div class="mb-3">
            <label class="form-label" for="cfg_allowed_domains">{{ __('Allowed domains', 'googlessoauth') }}</label>
            <input type="text" class="form-control" id="cfg_allowed_domains" name="allowed_domains"
                   value="{{ allowed_domains }}" placeholder="example.com, example.org"/>
            <small class="form-hint text-muted">
                {{ __('Comma-separated list of Google Workspace domains allowed to authenticate. Leave empty to allow any domain (the GLPI user match still applies).', 'googlessoauth') }}
            </small>
        </div>

        <div class="card-footer text-end">
            <button type="submit" name="update" class="btn btn-primary">
                <i class="ti ti-device-floppy me-1"></i>{{ __('Save') }}
            </button>
        </div>
    </form>
</div>
