# Keep secrets, local tooling and build artifacts out of the image context.
.env
.env.*
!.env.example

.git
.github
.gitignore
.devcontainer

node_modules
vendor

# Frontend build artifacts are produced by the dedicated build stage and
# copied explicitly; do not ship sources' intermediate output via `COPY .`.
public/dist

# Dev-only tooling & metadata
tests
tools
Makefile
*.log
*.md
docker-compose.yml
Dockerfile
.php-cs-fixer.php
phpstan.neon
phpunit.xml
psalm.xml
rector.php
eslint.config.mjs
.stylelintrc.js
.twig_cs.dist.php

// Cookie SameSite must be defined as Lax
local_define.php